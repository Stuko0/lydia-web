---
import Layout from "../../components/Layout.astro";
import HeroSection from "../../components/HeroSection.astro";
import HeroTerminal from "../../components/HeroTerminal.astro";
import AnimatedBackground from "../../components/AnimatedBackground.astro";
import Stats from "../../components/Stats.astro";
import WhyLydia from "../../components/WhyLydia.astro";
import HowItWorks from "../../components/HowItWorks.astro";
import UseCases from "../../components/UseCases.astro";
import Testimonials from "../../components/Testimonials.astro";
import FAQ from "../../components/FAQ.astro";
import Roadmap from "../../components/Roadmap.astro";
import DesktopDownload from "../../components/DesktopDownload.astro";
import { InstallCommand } from "../../components/InstallCommand";
import { RotatingCard } from "../../components/RotatingCard";
import { ScrollReveal } from "../../components/ScrollReveal";
import { FeatureCard } from "../../components/FeatureCard";
import { ArrowRight, Heart } from "lucide-react";
import { getT } from "../../i18n.server";

export const getStaticPaths = () => [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "it" } }];

const lng = (Astro.currentLocale ?? "es") as "es" | "en" | "it";
const t = getT(lng);

const features = [
  { iconName: "Brain" as const, title: t.features.persistentMemory, desc: t.features.persistentMemoryDesc, color: "iris" as const },
  { iconName: "Eye" as const, title: t.features.webBrowse, desc: t.features.webBrowseDesc, color: "foam" as const },
  { iconName: "Heart" as const, title: t.features.creative, desc: t.features.creativeDesc, color: "love" as const },
  { iconName: "Clock" as const, title: t.features.scheduled, desc: t.features.scheduledDesc, color: "gold" as const },
  { iconName: "Shield" as const, title: t.features.sandbox, desc: t.features.sandboxDesc, color: "pine" as const },
  { iconName: "Sparkles" as const, title: t.features.astroIslands, desc: t.features.astroIslandsDesc, color: "rose" as const },
];

const slidesText = [
  { title: t.featurePreview.slides.memory, desc: t.features.persistentMemoryDesc },
  { title: t.featurePreview.slides.automation, desc: t.features.scheduledDesc },
  { title: t.featurePreview.slides.browse, desc: t.features.webBrowseDesc },
  { title: t.featurePreview.slides.sandbox, desc: t.features.sandboxDesc },
  { title: t.featurePreview.slides.creative, desc: t.features.creativeDesc },
  { title: t.featurePreview.slides.schedule, desc: t.features.scheduledDesc },
];

const title = `Lydia Agent — ${t.hero.title}`;
const description = t.hero.description;
const version = "0.17.0";
---

<Layout title={title} description={description}>
  <HeroSection
    badge={t.hero.badge}
    title={t.hero.title}
    description={t.hero.description}
    primaryCta={t.hero.primaryCta}
    secondaryCta={t.hero.secondaryCta}
    lng={lng}
  >
    <div slot="visual">
      <HeroTerminal title={t.hero.terminal} />
    </div>
  </HeroSection>

  <Stats stars="128" version="0.1.0" langs="3" />

  <WhyLydia
    title={t.why.title}
    subtitle={t.why.subtitle}
    withoutTitle={t.why.without}
    withTitle={t.why.with}
    rows={t.why.rows}
  />

  <HowItWorks
    title={t.how.title}
    subtitle={t.how.subtitle}
    steps={t.how.steps}
  />

  <UseCases
    title={t.useCases.title}
    subtitle={t.useCases.subtitle}
    cases={t.useCases.cases}
  />

  <Roadmap
    title={t.roadmap.title}
    subtitle={t.roadmap.subtitle}
    phases={t.roadmap.phases}
  />

  <section id="features" class="relative overflow-hidden py-24 bg-rpm-base">
    <div class="absolute inset-0 -z-10 opacity-30 bg-[radial-gradient(ellipse_at_bottom_right,_var(--color-rpm-love)_0%,_transparent_45%)]" aria-hidden></div>
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
        <div class="space-y-6">
          <ScrollReveal client:visible>
            <div class="inline-flex items-center gap-2 rounded-full border border-rpm-love/30 bg-rpm-love/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-rpm-love">
              <Heart className="h-3.5 w-3.5" />
              {t.featurePreview.badge}
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.1}>
            <h2 class="font-display text-4xl leading-tight text-rpm-text sm:text-5xl text-balance">
              {t.featurePreview.title}
            </h2>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.2}>
            <p class="max-w-lg text-lg text-rpm-subtle">
              {t.featurePreview.description}
            </p>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.3}>
            <div class="flex flex-wrap gap-4">
              <a href={`/${lng}/features`} class="inline-flex items-center gap-2 rounded-full bg-rpm-iris px-6 py-3 font-medium text-rpm-base transition hover:bg-rpm-foam hover:text-rpm-base">
                {t.featurePreview.ctaFeatures} <ArrowRight className="h-4 w-4" />
              </a>
              <a href={`/${lng}/docs`} class="inline-flex items-center gap-2 rounded-full border border-rpm-highlight-med/40 bg-rpm-surface/60 px-6 py-3 font-medium text-rpm-text transition hover:border-rpm-iris hover:text-rpm-iris">
                {t.featurePreview.ctaDocs}
              </a>
            </div>
          </ScrollReveal>
        </div>
        <div class="relative">
          <RotatingCard client:visible slidesText={slidesText} />
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-rpm-highlight-low/60 bg-rpm-surface/30 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal client:visible>
        <div class="mb-16 text-center">
          <h2 class="font-display text-3xl text-rpm-text sm:text-4xl">{t.featuresGrid.title}</h2>
          <p class="mt-3 text-rpm-muted">{t.featuresGrid.subtitle}</p>
        </div>
      </ScrollReveal>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <FeatureCard client:visible title={f.title} description={f.desc} iconName={f.iconName} color={f.color} index={i} />
        ))}
      </div>
    </div>
  </section>

  <Testimonials
    title={t.testimonials.title}
    subtitle={t.testimonials.subtitle}
    testimonials={t.testimonials.items}
  />

  <FAQ
    title={t.faq.title}
    subtitle={t.faq.subtitle}
    items={t.faq.items}
  />

  <section class="relative overflow-hidden py-24 bg-rpm-base">
    <div class="absolute inset-0 -z-10 opacity-40 bg-[radial-gradient(ellipse_at_center,_var(--color-rpm-iris)_0%,_transparent_60%)]" aria-hidden></div>
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="font-display text-4xl text-rpm-text sm:text-5xl text-balance">{t.cta.title}</h2>
      <p class="mt-4 text-lg text-rpm-subtle">{t.cta.subtitle}</p>
      <div class="mt-10 space-y-6">
        <a href={`/${lng}/#install`} class="inline-flex items-center gap-2 rounded-full bg-rpm-iris px-8 py-4 text-lg font-medium text-rpm-base transition hover:bg-rpm-foam hover:text-rpm-base">
          {t.cta.button} <ArrowRight className="h-5 w-5" />
        </a>
      </div>
      <div id="install" class="mt-10">
        <InstallCommand client:load />
      </div>

      <!-- Desktop Downloads -->
      <div class="mt-16">
        <DesktopDownload />
      </div>

      <p class="mt-6 text-xs text-rpm-muted text-center">
        The desktop app bundles its own Python runtime — no separate install needed.
        <a href="https://github.com/Stuko0/lydia-agent/releases" class="text-rpm-iris hover:underline ml-1">See all releases &rarr;</a>
      </p>
      </div>
    </div>
  </section>
</Layout>
