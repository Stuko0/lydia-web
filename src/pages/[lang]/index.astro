---
import Layout from "../../components/Layout.astro";
import { FloatingOrbs } from "../../components/FloatingOrbs";
import { InstallCommand } from "../../components/InstallCommand";
import { RotatingCard } from "../../components/RotatingCard";
import { ScrollReveal } from "../../components/ScrollReveal";
import { FeatureCard } from "../../components/FeatureCard";
import { Apple, Monitor, Terminal, ArrowRight, Sparkles, Heart } from "lucide-react";
import { getT } from "../../i18n.server";

export const getStaticPaths = () => [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "it" } }];

const lng = (Astro.currentLocale ?? "es") as "es" | "en" | "it";
const t = getT(lng);

const platforms = [
  { icon: Apple, label: t.platforms.macos, sub: t.platforms.macosSub, href: "#install", color: "#c4a7e7" },
  { icon: Monitor, label: t.platforms.windows, sub: t.platforms.windowsSub, href: "#install", color: "#3e8fb0" },
  { icon: Terminal, label: t.platforms.linux, sub: t.platforms.linuxSub, href: "#install", color: "#9ccfd8" },
];

const features = [
  { iconName: "Brain" as const, title: t.features.persistentMemory, desc: t.features.persistentMemoryDesc, color: "iris" as const },
  { iconName: "Eye" as const, title: t.features.webBrowse, desc: t.features.webBrowseDesc, color: "foam" as const },
  { iconName: "Heart" as const, title: t.features.creative, desc: t.features.creativeDesc, color: "love" as const },
  { iconName: "Clock" as const, title: t.features.scheduled, desc: t.features.scheduledDesc, color: "gold" as const },
  { iconName: "Shield" as const, title: t.features.sandbox, desc: t.features.sandboxDesc, color: "pine" as const },
  { iconName: "Sparkles" as const, title: t.features.astroIslands, desc: t.features.astroIslandsDesc, color: "rose" as const },
];

const title = `Lydia Agent — ${t.hero.title}`;
---

<Layout title={title}>
  <section class="relative flex min-h-[92vh] items-center overflow-hidden border-b border-rpm-highlight-low/60 bg-rpm-base">
    <FloatingOrbs client:load />
    <div class="absolute inset-0 mask-radial-fade bg-[radial-gradient(ellipse_at_top,_var(--color-rpm-iris)_0%,_transparent_50%)] opacity-20" aria-hidden></div>

    <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-6 py-20 lg:grid-cols-2">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-rpm-iris/30 bg-rpm-iris/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-rpm-iris">
          <Sparkles className="h-3.5 w-3.5" />
          {t.hero.badge}
        </div>
        <h1 class="font-display text-5xl leading-[1.05] text-rpm-text sm:text-6xl lg:text-7xl text-balance">
          {t.hero.title}
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-rpm-subtle">
          {t.hero.description}
        </p>
        <div id="install" class="space-y-4">
          <InstallCommand client:load />
        </div>
      </div>

      <div class="relative flex items-center justify-center">
        <div class="absolute inset-0 -z-10 rounded-full bg-gradient-to-br from-rpm-iris/30 via-rpm-rose/20 to-rpm-love/30 blur-3xl" aria-hidden></div>
        <img src="/hero-art.svg" alt="Lydia Agent illustration inspired by Alice Madness Returns" class="relative z-10 max-w-[420px] w-full rounded-3xl drop-shadow-2xl transition-transform duration-700 hover:scale-[1.02]" />
      </div>
    </div>
  </section>

  <section class="border-b border-rpm-highlight-low/60 bg-rpm-surface/40 py-20">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal client:visible>
        <div class="mb-12 text-center">
          <h2 class="font-display text-3xl text-rpm-text sm:text-4xl">{t.platforms.title}</h2>
          <p class="mt-3 text-rpm-muted">{t.platforms.subtitle}</p>
        </div>
      </ScrollReveal>
      <div class="grid gap-6 sm:grid-cols-3">
        {platforms.map((p, i) => (
          <ScrollReveal client:visible delay={i * 0.1}>
            <a href={`/${lng}${p.href}`} class="group relative flex flex-col items-center gap-4 rounded-2xl border border-rpm-highlight-med/40 bg-rpm-base/60 p-8 transition-all hover:-translate-y-2 hover:border-rpm-iris/50 hover:shadow-xl">
              <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-current/20 bg-rpm-surface/80 transition group-hover:scale-110" style={`color:${p.color}`}>
                <p.icon className="h-8 w-8" />
              </div>
              <div class="text-center">
                <h3 class="font-display text-xl text-rpm-text">{p.label}</h3>
                <p class="text-sm text-rpm-muted">{p.sub}</p>
              </div>
              <span class="mt-2 flex items-center gap-1 text-sm font-medium text-rpm-iris opacity-0 transition group-hover:opacity-100">
                {t.platforms.install} <ArrowRight className="h-4 w-4" />
              </span>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden py-24 bg-rpm-base">
    <div class="absolute inset-0 -z-10 opacity-30 bg-[radial-gradient(ellipse_at_bottom_right,_var(--color-rpm-love)_0%,_transparent_45%)]" aria-hidden></div>
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
        <div class="space-y-6">
          <ScrollReveal client:visible>
            <div class="inline-flex items-center gap-2 rounded-full border border-rpm-love/30 bg-rpm-love/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-rpm-love">
              <Heart className="h-3.5 w-3.5" />
              {t.featurePreview.badge}
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.1}>
            <h2 class="font-display text-4xl leading-tight text-rpm-text sm:text-5xl text-balance">
              {t.featurePreview.title}
            </h2>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.2}>
            <p class="max-w-lg text-lg text-rpm-subtle">
              {t.featurePreview.description}
            </p>
          </ScrollReveal>
          <ScrollReveal client:visible delay={0.3}>
            <div class="flex gap-4">
              <a href={`/${lng}/features`} class="inline-flex items-center gap-2 rounded-full bg-rpm-iris px-6 py-3 font-medium text-rpm-base transition hover:bg-rpm-foam hover:text-rpm-base">
                {t.featurePreview.ctaFeatures} <ArrowRight className="h-4 w-4" />
              </a>
              <a href={`/${lng}/docs`} class="inline-flex items-center gap-2 rounded-full border border-rpm-highlight-med/40 bg-rpm-surface/60 px-6 py-3 font-medium text-rpm-text transition hover:border-rpm-iris hover:text-rpm-iris">
                {t.featurePreview.ctaDocs}
              </a>
            </div>
          </ScrollReveal>
        </div>
        <div class="relative">
          <RotatingCard client:visible />
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-rpm-highlight-low/60 bg-rpm-surface/30 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <ScrollReveal client:visible>
        <div class="mb-16 text-center">
          <h2 class="font-display text-3xl text-rpm-text sm:text-4xl">{t.featuresGrid.title}</h2>
          <p class="mt-3 text-rpm-muted">{t.featuresGrid.subtitle}</p>
        </div>
      </ScrollReveal>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <FeatureCard client:visible title={f.title} description={f.desc} iconName={f.iconName} color={f.color} index={i} />
        ))}
      </div>
    </div>
  </section>
</Layout>
