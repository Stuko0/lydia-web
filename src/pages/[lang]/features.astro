---
import Layout from "../../components/Layout.astro";
import { ScrollReveal } from "../../components/ScrollReveal";
import { FeatureCard } from "../../components/FeatureCard";
import { Sparkles } from "lucide-react";
import { getT } from "../../i18n.server";

export const getStaticPaths = () => [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "it" } }];

const lng = (Astro.currentLocale ?? "es") as "es" | "en" | "it";
const t = getT(lng);

const allFeatures = [
  { iconName: "Brain", title: t.features.persistentMemory, desc: t.features.persistentMemoryDesc },
  { iconName: "Eye", title: t.features.webBrowse, desc: t.features.webBrowseDesc },
  { iconName: "Heart", title: t.features.creative, desc: t.features.creativeDesc },
  { iconName: "Clock", title: t.features.scheduled, desc: t.features.scheduledDesc },
  { iconName: "Shield", title: t.features.sandbox, desc: t.features.sandboxDesc },
  { iconName: "Sparkles", title: t.features.astroIslands, desc: t.features.astroIslandsDesc },
  { iconName: "Terminal", title: t.features.cli, desc: t.features.cliDesc },
  { iconName: "Globe", title: t.features.integrations, desc: t.features.integrationsDesc },
  { iconName: "MessageSquare", title: t.features.contextual, desc: t.features.contextualDesc },
  { iconName: "Music", title: t.features.audio, desc: t.features.audioDesc },
  { iconName: "Palette", title: t.features.visual, desc: t.features.visualDesc },
  { iconName: "Code", title: t.features.code, desc: t.features.codeDesc },
];

const title = `${t.nav.features} — Lydia Agent`;
---

<Layout title={title}>
  <section class="relative overflow-hidden border-b border-rpm-highlight-low/60 bg-rpm-base py-28">
    <div class="fabric-pattern"></div>
    <div class="section-vignette"></div>
    <div class="glow-orb glow-orb-1" style="background: var(--color-rpm-love)"></div>
    <div class="absolute top-20 left-8 text-6xl font-bold text-rpm-love/6 select-none hidden md:block" aria-hidden>♥</div>
    <div class="absolute bottom-20 right-8 text-6xl font-bold text-rpm-gold/6 select-none hidden md:block" aria-hidden>♣</div>

    <div class="relative mx-auto max-w-4xl px-6 text-center">
      <div class="header-ornate">
        <span class="suit-heart">♥</span>
        <span class="line" style="background: linear-gradient(90deg, transparent, var(--color-rpm-love))"></span>
        <span class="suit-spade">♠</span>
        <span class="line" style="background: linear-gradient(90deg, var(--color-rpm-love), transparent)"></span>
        <span class="suit-heart">♥</span>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full border border-rpm-love/30 bg-rpm-love/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-rpm-love">
        <Sparkles class="h-3.5 w-3.5" />
        {t.featurePreview.badge}
        <span class="opacity-40" aria-hidden>♥</span>
      </div>
      <h1 class="mt-6 font-display text-5xl leading-tight text-rpm-text sm:text-6xl text-balance">{t.nav.features}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-rpm-subtle">{t.featuresGrid.subtitle}</p>
    </div>
  </section>

  <section class="relative overflow-hidden bg-rpm-surface/20 py-24">
    <div class="fabric-pattern"></div>
    <div class="section-vignette"></div>

    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {allFeatures.map((f, i) => (
          <FeatureCard client:visible title={f.title} description={f.desc} iconName={f.iconName} index={i} />
        ))}
      </div>
    </div>
  </section>
</Layout>
