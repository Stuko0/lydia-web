---
interface Props {
  title: string;
  subtitle: string;
  testimonials: { quote: string; author: string; role: string }[];
}

const { title, subtitle, testimonials } = Astro.props;
---

<section class="relative overflow-hidden py-24 bg-rpm-base">
  <div class="absolute inset-0 -z-10 opacity-25 bg-[radial-gradient(ellipse_at_top,_var(--color-rpm-iris)_0%,_transparent_60%)]" aria-hidden></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center">
      <h2 class="font-display text-3xl text-rpm-text sm:text-4xl text-balance">{title}</h2>
      <p class="mt-3 text-rpm-muted">{subtitle}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <div class="rounded-2xl border border-rpm-highlight-med/40 bg-rpm-surface/60 p-8">
          <div class="mb-5 text-2xl leading-none text-rpm-iris">"</div>
          <p class="text-sm leading-relaxed text-rpm-subtle">{t.quote}</p>
          <div class="mt-6 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-rpm-iris/10 font-display text-sm font-bold text-rpm-iris">
              {t.author.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-medium text-rpm-text">{t.author}</div>
              <div class="text-xs text-rpm-muted">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
