---
interface Props {
  title: string;
  subtitle: string;
  testimonials: { quote: string; author: string; role: string }[];
}

const { title, subtitle, testimonials } = Astro.props;
const suits = ["♠", "♥", "♦"];
const colors = ["suit-spade", "suit-heart", "suit-diamond"];
const borders = ["border-suit-spade", "border-suit-heart", "border-suit-diamond"];
const bgs = ["bg-suit-spade", "bg-suit-heart", "bg-suit-diamond"];
const tilts = ["card-tilt-left", "", "card-tilt-right"];
---

<section class="relative overflow-hidden py-24 bg-rpm-base">
  <div class="fabric-pattern"></div>
  <div class="glow-orb glow-orb-1" style="background: var(--color-rpm-foam)"></div>
  <div class="section-vignette"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center">
      <div class="header-ornate">
        <span class="suit-heart">♥</span>
        <span class="line" style="background: linear-gradient(90deg, transparent, var(--color-rpm-foam))"></span>
        <span class="suit-spade">♠</span>
        <span class="line" style="background: linear-gradient(90deg, var(--color-rpm-foam), transparent)"></span>
        <span class="suit-heart">♥</span>
      </div>
      <h2 class="font-display text-3xl text-rpm-text sm:text-4xl text-balance">{title}</h2>
      <p class="mt-3 text-rpm-muted">{subtitle}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {testimonials.map((t, i) => {
        const suit = suits[i % suits.length];
        const color = colors[i % colors.length];
        const border = borders[i % borders.length];
        const bg = bgs[i % bgs.length];
        const tilt = tilts[i % tilts.length];
        return (
          <div class={`card-alice ${tilt} ${border} ${bg}`}>
            <span class={`suit-watermark ${color}`}>{suit}</span>
            <span class={`suit-corner suit-corner-tl ${color}`}>{suit}</span>
            <span class={`suit-corner suit-corner-br ${color}`}>{suit}</span>
            <div class="p-8 pt-14">
              <div class={`mb-4 text-3xl leading-none font-serif ${color}`}>"</div>
              <p class="text-sm leading-relaxed text-rpm-subtle">{t.quote}</p>
              <div class="divider-ornate"></div>
              <div class="flex items-center gap-3">
                <div class={`flex h-10 w-10 items-center justify-center rounded-full border-2 ${border} ${color} font-display text-sm font-bold`}>
                  {t.author.charAt(0)}
                </div>
                <div>
                  <div class="text-sm font-medium text-rpm-text">{t.author}</div>
                  <div class="text-xs text-rpm-muted">{t.role}</div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
