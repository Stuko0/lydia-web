---
interface Props {
  title: string;
  subtitle: string;
  steps: { number: string; title: string; desc: string }[];
}

const { title, subtitle, steps } = Astro.props;
const suits = ["♠", "♥", "♦"];
const colorClasses = ["suit-spade", "suit-heart", "suit-diamond"];
const borderClasses = ["border-suit-spade", "border-suit-heart", "border-suit-diamond"];
const bgClasses = ["bg-suit-spade", "bg-suit-heart", "bg-suit-diamond"];
const tilts = ["card-tilt-left", "", "card-tilt-right"];
---

<section class="relative overflow-hidden py-24 bg-rpm-base">
  <div class="fabric-pattern"></div>
  <div class="glow-orb glow-orb-1" style="background: var(--color-rpm-pine)"></div>
  <div class="section-vignette"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center">
      <div class="header-ornate">
        <span class="suit-spade">♠</span>
        <span class="line" style="background: linear-gradient(90deg, transparent, var(--color-rpm-iris))"></span>
        <span class="suit-diamond">♦</span>
        <span class="line" style="background: linear-gradient(90deg, var(--color-rpm-iris), transparent)"></span>
        <span class="suit-spade">♠</span>
      </div>
      <h2 class="font-display text-3xl text-rpm-text sm:text-4xl text-balance">{title}</h2>
      <p class="mt-3 text-rpm-muted">{subtitle}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {steps.map((step, i) => {
        const suit = suits[i];
        const color = colorClasses[i];
        const border = borderClasses[i];
        const bg = bgClasses[i];
        const tilt = tilts[i];
        return (
          <div class={`card-alice ${tilt} ${border} ${bg}`}>
            <span class="suit-watermark" class:list={[color]}>{suit}</span>
            <span class="suit-corner suit-corner-tl" class:list={[color]}>{suit}</span>
            <span class="suit-corner suit-corner-br" class:list={[color]}>{suit}</span>
            <div class="p-8 pt-14 text-center">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full border-2 currentcolor bg-rpm-base/60 font-display text-xl font-bold" class:list={[border, color]}>
                {step.number}
              </div>
              <h3 class="font-display text-xl text-rpm-text mb-2">{step.title}</h3>
              <p class="text-sm text-rpm-subtle">{step.desc}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
