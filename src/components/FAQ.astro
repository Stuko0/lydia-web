---
interface Props {
  title: string;
  subtitle: string;
  items: { q: string; a: string }[];
}

const { title, subtitle, items } = Astro.props;
---

<section class="relative overflow-hidden py-24 bg-rpm-surface/30">
  <div class="fabric-pattern"></div>
  <div class="section-vignette"></div>

  <div class="mx-auto max-w-3xl px-6">
    <div class="mb-16 text-center">
      <div class="header-ornate">
        <span class="suit-club">♣</span>
        <span class="line" style="background: linear-gradient(90deg, transparent, var(--color-rpm-gold))"></span>
        <span class="suit-diamond">♦</span>
        <span class="line" style="background: linear-gradient(90deg, var(--color-rpm-gold), transparent)"></span>
        <span class="suit-club">♣</span>
      </div>
      <h2 class="font-display text-3xl text-rpm-text sm:text-4xl text-balance">{title}</h2>
      <p class="mt-3 text-rpm-muted">{subtitle}</p>
    </div>

    <div class="space-y-3">
      {items.map((item, i) => (
        <details class="card-alice group overflow-hidden border-rpm-highlight-med/40 bg-rpm-base/60 transition-all open:!border-rpm-iris/40 open:bg-rpm-surface/60">
          <span class="suit-watermark suit-spade">♠</span>
          <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-5 text-rpm-text transition group-hover:text-rpm-iris">
            <span class="font-medium text-sm pr-4">{item.q}</span>
            <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-rpm-highlight-med text-sm text-rpm-subtle transition group-open:rotate-45 group-open:border-rpm-iris group-open:text-rpm-iris">+</span>
          </summary>
          <p class="px-6 pb-5 text-sm leading-relaxed text-rpm-subtle">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
