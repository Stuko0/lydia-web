---
import { Check, X } from "lucide-react";

interface Props {
  title: string;
  subtitle: string;
  withoutTitle: string;
  withTitle: string;
  rows: { without: string; with: string }[];
}

const { title, subtitle, withoutTitle, withTitle, rows } = Astro.props;
---

<section class="relative overflow-hidden border-b border-rpm-highlight-low/60 bg-rpm-surface/40 py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center">
      <h2 class="font-display text-3xl text-rpm-text sm:text-4xl text-balance">{title}</h2>
      <p class="mt-3 text-rpm-muted">{subtitle}</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Sin Lydia -->
      <div class="rounded-2xl border border-rpm-love/30 bg-rpm-base/80 p-8">
        <h3 class="mb-6 font-display text-xl text-rpm-love">{withoutTitle}</h3>
        <ul class="space-y-4">
          {rows.map((row) => (
            <li class="flex items-start gap-3 text-rpm-subtle">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rpm-love/10 text-rpm-love">
                <X class="h-3 w-3" />
              </span>
              {row.without}
            </li>
          ))}
        </ul>
      </div>

      <!-- Con Lydia -->
      <div class="relative rounded-2xl border border-rpm-iris/40 bg-rpm-base/80 p-8 shadow-[0_0_40px_-12px_rgba(196,167,231,0.15)]">
        <div class="absolute -top-3 left-8 rounded-full bg-rpm-iris px-3 py-1 text-xs font-semibold uppercase tracking-wider text-rpm-base">Lydia</div>
        <h3 class="mb-6 font-display text-xl text-rpm-iris">{withTitle}</h3>
        <ul class="space-y-4">
          {rows.map((row) => (
            <li class="flex items-start gap-3 text-rpm-text">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rpm-iris/10 text-rpm-iris">
                <Check class="h-3 w-3" />
              </span>
              {row.with}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
