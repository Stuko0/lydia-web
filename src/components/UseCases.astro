---
import { Terminal, Palette, Calendar, Shield } from "lucide-react";

interface Props {
  title: string;
  subtitle: string;
  cases: { icon: string; title: string; desc: string }[];
}

const { title, subtitle, cases } = Astro.props;
const icons: Record<string, any> = { Terminal, Palette, Calendar, Shield };
const suits = ["♠", "♥", "♣", "♦"];
const colorClasses = ["suit-spade", "suit-heart", "suit-club", "suit-diamond"];
const borderClasses = ["border-suit-spade", "border-suit-heart", "border-suit-club", "border-suit-diamond"];
const bgClasses = ["bg-suit-spade", "bg-suit-heart", "bg-suit-club", "bg-suit-diamond"];
const tilts = ["card-tilt-left", "card-tilt-right", "card-tilt-left", "card-tilt-right"];
---

<section class="relative overflow-hidden py-24 bg-rpm-surface/30">
  <div class="fabric-pattern"></div>
  <div class="section-vignette"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center">
      <div class="header-ornate">
        <span class="suit-club">♣</span>
        <span class="line" style="background: linear-gradient(90deg, transparent, var(--color-rpm-gold))"></span>
        <span class="suit-diamond">♦</span>
        <span class="line" style="background: linear-gradient(90deg, var(--color-rpm-gold), transparent)"></span>
        <span class="suit-club">♣</span>
      </div>
      <h2 class="font-display text-3xl text-rpm-text sm:text-4xl text-balance">{title}</h2>
      <p class="mt-3 text-rpm-muted">{subtitle}</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {cases.map((c, i) => {
        const Icon = icons[c.icon] || Terminal;
        const suit = suits[i];
        const color = colorClasses[i];
        const border = borderClasses[i];
        const bg = bgClasses[i];
        const tilt = tilts[i];
        return (
          <div class={`card-alice ${tilt} ${border} ${bg}`}>
            <span class="suit-watermark" class:list={[color]}>{suit}</span>
            <span class="suit-corner suit-corner-tl" class:list={[color]}>{suit}</span>
            <span class="suit-corner suit-corner-br" class:list={[color]}>{suit}</span>
            <div class="p-8 pt-14">
              <div class="mb-4 inline-flex rounded-xl border-2 currentcolor bg-rpm-surface/80 p-3" class:list={[border, color]}>
                <Icon class="h-6 w-6" />
              </div>
              <h3 class="font-display text-xl text-rpm-text mb-2">{c.title}</h3>
              <p class="text-sm leading-relaxed text-rpm-subtle">{c.desc}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
