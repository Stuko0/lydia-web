---
import { Sparkles, ArrowRight, Play } from "lucide-react";

interface Props {
  badge: string;
  title: string;
  description: string;
  primaryCta: string;
  secondaryCta: string;
  lng: string;
}

const { badge, title, description, primaryCta, secondaryCta, lng } = Astro.props;
const suits = ["♠", "♥", "♦", "♣"];
---

<section class="relative flex min-h-[92vh] items-center overflow-hidden border-b border-rpm-highlight-low/60 bg-rpm-base">
  <div class="fabric-pattern"></div>
  <div class="glow-orb glow-orb-1" style="background: var(--color-rpm-iris)"></div>
  <div class="glow-orb glow-orb-2" style="background: var(--color-rpm-love)"></div>
  <div class="section-vignette"></div>

  <div class="absolute top-24 left-6 text-6xl font-bold text-rpm-iris/5 select-none hidden md:block" aria-hidden>♠</div>
  <div class="absolute bottom-32 right-8 text-6xl font-bold text-rpm-love/5 select-none hidden md:block" aria-hidden>♥</div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-6 py-20 lg:grid-cols-2">
    <div class="space-y-8">
      <div class="inline-flex items-center gap-2 rounded-full border border-rpm-iris/30 bg-rpm-iris/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-rpm-iris">
        <Sparkles class="h-3.5 w-3.5" />
        {badge}
        <span class="opacity-40" aria-hidden>♠</span>
      </div>
      <h1 class="font-display text-5xl leading-[1.05] text-rpm-text sm:text-6xl lg:text-7xl text-balance">
        {title}
      </h1>
      <p class="max-w-xl text-lg leading-relaxed text-rpm-subtle">
        {description}
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href={`/${lng}/#install`} class="group inline-flex items-center gap-2 rounded-full bg-rpm-iris px-6 py-3.5 font-medium text-rpm-base transition hover:bg-rpm-foam hover:text-rpm-base">
          {primaryCta}
          <ArrowRight class="h-4 w-4 transition group-hover:translate-x-1" />
        </a>
        <a href={`/${lng}/features`} class="inline-flex items-center gap-2 rounded-full border border-rpm-highlight-med/40 bg-rpm-surface/60 px-6 py-3.5 font-medium text-rpm-text transition hover:border-rpm-iris hover:text-rpm-iris">
          <Play class="h-4 w-4" />
          {secondaryCta}
        </a>
      </div>
    </div>
    <div class="relative flex items-center justify-center">
      <div class="absolute -inset-8 rounded-full bg-gradient-to-br from-rpm-iris/20 via-rpm-rose/10 to-rpm-love/15 blur-3xl" aria-hidden></div>
      <div class="absolute top-0 right-0 text-8xl font-bold text-rpm-foam/4 select-none" aria-hidden>♦</div>
      <div class="absolute bottom-0 left-0 text-8xl font-bold text-rpm-gold/4 select-none" aria-hidden>♣</div>
      <slot name="visual" />
    </div>
  </div>
</section>
