---
export interface Props {
  stars: string;
  version: string;
  langs: string;
}
const { stars, version, langs } = Astro.props;
const statItems = [
  { value: stars, label: "GitHub Stars", suit: "♠" },
  { value: version, label: "Latest Version", suit: "♦" },
  { value: langs, label: "Languages", suit: "♣" },
];
---

<section class="relative overflow-hidden py-20 bg-rpm-base">
  <div class="fabric-pattern"></div>
  <div class="section-vignette"></div>

  <div class="mx-auto max-w-5xl px-6">
    <div class="grid gap-4 sm:grid-cols-3">
      {statItems.map((stat, i) => (
        <div class="card-alice text-center px-8 py-8">
          <span class="suit-watermark" class:list={[`suit-${['heart','spade','diamond','club'][i]}`, i === 0 ? "text-rpm-love" : i === 1 ? "text-rpm-iris" : "text-rpm-gold"]}>{stat.suit}</span>
          <span class="suit-corner suit-corner-tl" class:list={[i === 0 ? "suit-heart text-rpm-love" : i === 1 ? "suit-spade text-rpm-iris" : "suit-club text-rpm-gold"]}>{stat.suit}</span>
          <span class="suit-corner suit-corner-br" class:list={[i === 0 ? "suit-heart text-rpm-love" : i === 1 ? "suit-spade text-rpm-iris" : "suit-club text-rpm-gold"]}>{stat.suit}</span>

          <span class="stat-number" data-target={i === 1 ? undefined : stat.value} data-version={i === 1 ? stat.value : undefined}>{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    document.querySelectorAll('.stat-number[data-target]').forEach((el) => {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      const duration = 1500;
      const start = performance.now();
      const animate = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 4);
        el.textContent = Math.floor(eased * target).toString();
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    });
  })();
</script>

<style>
  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    background: linear-gradient(135deg, var(--color-rpm-iris), var(--color-rpm-foam));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1;
  }
  .stat-label {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-rpm-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
